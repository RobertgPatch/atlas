NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atlas
SESSION_COOKIE_NAME=atlas_session
SESSION_COOKIE_SECURE=false
SESSION_IDLE_TIMEOUT_SECONDS=900
SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
AUTH_LOCKOUT_THRESHOLD=3
AUTH_LOCKOUT_MINUTES=30
TOTP_ISSUER=Atlas

# Azure Document Intelligence — K-1 extraction backend
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
# AZURE_DOCUMENT_INTELLIGENCE_KEY=<your-subscription-key>
# AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30
# AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=<your-custom-or-composed-model-id>

# Extractor backend: stub (offline/CI default) | azure (real API)
# K1_EXTRACTOR=stub